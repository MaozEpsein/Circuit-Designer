    { "id": "wr2", "sourceId": "ready_in", "targetId": "hs_2", "targetInputIndex": 1, "sourceOutputIndex": 0, "waypoints": [], "netName": "ready", "colorGroup": null, "isClockWire": false },
    { "id": "ws2", "sourceId": "hs_2",     "targetId": "p2",   "targetInputIndex": 1, "sourceOutputIndex": 0, "waypoints": [], "netName": "stall", "colorGroup": null, "isClockWire": false },
