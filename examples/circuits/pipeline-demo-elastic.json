    { "id": "wr1", "sourceId": "ready_in", "targetId": "hs_1", "targetInputIndex": 1, "sourceOutputIndex": 0, "waypoints": [], "netName": "ready", "colorGroup": null, "isClockWire": false },
    { "id": "ws1", "sourceId": "hs_1",     "targetId": "p1",   "targetInputIndex": 1, "sourceOutputIndex": 0, "waypoints": [], "netName": "stall", "colorGroup": null, "isClockWire": false },

