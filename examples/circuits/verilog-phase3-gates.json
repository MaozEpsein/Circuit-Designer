{
  "_doc": "Phase-3 demo: combinational gates round-trip. Three primary inputs (a, b, c), an AND, an OR, an XOR, all wired so OUT = (a & b) | (a ^ c). Click VERILOG in the bottom toolbar to download circuit.v — the export pipeline lowers each gate to a Verilog primitive (`and`, `or`, `xor` with positional ports). The downloaded file parses cleanly with iverilog (L1) and simulates bit-for-bit identical to the on-canvas engine (L2).",
  "nodes": [
    { "type": "INPUT",     "x": -260, "y": -100, "fixedValue": 1, "label": "a", "id": "in_a" },
    { "type": "INPUT",     "x": -260,    "y": 0, "fixedValue": 1, "label": "b", "id": "in_b" },
    { "type": "INPUT",     "x": -260,  "y": 100, "fixedValue": 0, "label": "c", "id": "in_c" },

    { "type": "GATE_SLOT", "x":  -80,  "y": -50, "gate": "AND", "label": "AND",   "id": "g_and" },
    { "type": "GATE_SLOT", "x":  -80,   "y": 80, "gate": "XOR", "label": "XOR",   "id": "g_xor" },
    { "type": "GATE_SLOT", "x":  100,    "y": 0, "gate": "OR",  "label": "OR",    "id": "g_or"  },

    { "type": "OUTPUT",    "x":  280,    "y": 0, "targetValue": 1, "sandbox": true, "label": "y", "id": "out_y" }
  ],
  "wires": [
    { "sourceId": "in_a",  "targetId": "g_and", "targetInputIndex": 0, "sourceOutputIndex": 0, "id": "w_a_and" },
    { "sourceId": "in_b",  "targetId": "g_and", "targetInputIndex": 1, "sourceOutputIndex": 0, "id": "w_b_and" },
    { "sourceId": "in_a",  "targetId": "g_xor", "targetInputIndex": 0, "sourceOutputIndex": 0, "id": "w_a_xor" },
    { "sourceId": "in_c",  "targetId": "g_xor", "targetInputIndex": 1, "sourceOutputIndex": 0, "id": "w_c_xor" },
    { "sourceId": "g_and", "targetId": "g_or",  "targetInputIndex": 0, "sourceOutputIndex": 0, "id": "w_and_or" },
    { "sourceId": "g_xor", "targetId": "g_or",  "targetInputIndex": 1, "sourceOutputIndex": 0, "id": "w_xor_or" },
    { "sourceId": "g_or",  "targetId": "out_y", "targetInputIndex": 0, "sourceOutputIndex": 0, "id": "w_or_y" }
  ]
}
