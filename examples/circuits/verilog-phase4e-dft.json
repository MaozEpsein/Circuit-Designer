    { "sourceId": "te_in", "targetId": "sff", "targetInputIndex": 2, "id": "w_te" },
    { "sourceId": "clk",   "targetId": "sff", "targetInputIndex": 3, "isClockWire": true, "id": "w_sf_clk" },
