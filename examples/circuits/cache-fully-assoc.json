{
  "_comment": "Layer 4 demo — workload that thrashes a 2-way set-associative cache but hits cleanly in fully-associative. The trace cycles 3 addresses (0, 4, 8) that all map to set 0 of a 2-way 4-line cache (idx = addr & 1 = 0; tags 0/2/4). Three competing tags into a 2-way set ⇒ every access is a miss (LRU keeps evicting). Fully-associative with 4 lines stores all three tags simultaneously ⇒ after 3 compulsory misses, every access HITS. Open the Pipeline panel CACHE (LIVE) section to compare hit rates side by side.",
  "nodes": [
    { "type": "CLOCK", "id": "clk", "x": -640, "y":  280, "value": 0 },
    { "type": "INPUT", "id": "en",  "x": -640, "y":  140, "fixedValue": 1, "label": "EN" },
    { "type": "INPUT", "id": "rst", "x": -640, "y":  200, "fixedValue": 0, "label": "RST" },

    { "type": "PC",   "id": "pc",   "x": -460, "y":  200, "bitWidth": 3, "label": "PC" },

    { "type": "ROM",  "id": "rom",  "x": -260, "y":  200,
      "addrBits": 3, "dataBits": 8, "asyncRead": true,
      "memory": { "0": 0, "1": 4, "2": 8, "3": 0, "4": 4, "5": 8, "6": 0, "7": 4 },
      "label": "TRACE" },

    { "type": "INPUT", "id": "we",  "x": -640, "y":   60, "fixedValue": 0, "label": "WE" },
    { "type": "INPUT", "id": "re",  "x": -640, "y":    0, "fixedValue": 1, "label": "RE" },
    { "type": "INPUT", "id": "din", "x": -640, "y":  -60, "fixedValue": 0, "label": "DATA_IN" },

