    { "type": "OUTPUT", "id": "out_addr",   "x": -120, "y":  280, "label": "ADDR" },
    { "type": "OUTPUT", "id": "out_hit_2w", "x":  140, "y":  -20, "label": "2W_HIT" },
    { "type": "OUTPUT", "id": "out_mis_2w", "x":  140, "y":   40, "label": "2W_MISS" },
    { "type": "OUTPUT", "id": "out_hit_fa", "x":  140, "y":  180, "label": "FA_HIT" },
    { "type": "OUTPUT", "id": "out_mis_fa", "x":  140, "y":  240, "label": "FA_MISS" }
