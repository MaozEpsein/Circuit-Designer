    { "type": "RAM",   "id": "ram_fa",   "x":  280, "y":  220,
      "addrBits": 8, "dataBits": 8, "asyncRead": true,
      "memory": { "0": 100, "4": 200, "8": 80 },
      "label": "RAM-FA" },

