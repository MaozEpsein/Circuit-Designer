{
  "_comment": "Layer 6 demo — two-level memory hierarchy (L1 → L2 → RAM). The CACHE component nests in series: L1's CPU-side accepts the trace, L1's MEM-side drives L2's CPU-side, and L2's MEM-side drives the actual RAM. L1 is small (4 lines, direct-mapped) so it thrashes easily. L2 is larger (16 lines, fully-associative) and absorbs most of L1's misses — only the truly cold accesses reach RAM. Trace 0,4,8,12,16,20,0,4,8,12,16,20 cycles 6 distinct addresses: L1 (4 lines) misses every access; L2 (16 lines) misses only the first 6 (compulsory) and hits the rest. Open the Pipeline panel CACHE (LIVE) section to compare the two hit rates side by side.",
  "nodes": [
    { "type": "CLOCK", "id": "clk", "x": -700, "y":  280, "value": 0 },
    { "type": "INPUT", "id": "en",  "x": -700, "y":  140, "fixedValue": 1, "label": "EN" },
    { "type": "INPUT", "id": "rst", "x": -700, "y":  200, "fixedValue": 0, "label": "RST" },

    { "type": "PC",   "id": "pc",   "x": -540, "y":  200, "bitWidth": 4, "label": "PC" },

    { "type": "ROM",  "id": "rom",  "x": -360, "y":  200,
      "addrBits": 4, "dataBits": 8, "asyncRead": true,
      "memory": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 20,
                  "6": 0, "7": 4, "8": 8, "9": 12, "10": 16, "11": 20,
                  "12": 0, "13": 4, "14": 8, "15": 12 },
      "label": "TRACE" },

    { "type": "INPUT", "id": "we",  "x": -700, "y":   60, "fixedValue": 0, "label": "WE" },
    { "type": "INPUT", "id": "re",  "x": -700, "y":    0, "fixedValue": 1, "label": "RE" },
    { "type": "INPUT", "id": "din", "x": -700, "y":  -60, "fixedValue": 0, "label": "DATA_IN" },

    { "type": "CACHE", "id": "l1", "x":  -100, "y":  120,
      "lines": 4, "dataBits": 8, "addrBits": 8, "mapping": "direct", "label": "L1 (4 lines)" },
    { "type": "CACHE", "id": "l2", "x":  220, "y":  120,
      "lines": 16, "dataBits": 8, "addrBits": 8, "mapping": "fully-assoc", "label": "L2 (16 lines)" },

