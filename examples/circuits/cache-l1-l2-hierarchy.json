    { "type": "OUTPUT", "id": "out_l1_m", "x":   80, "y":   80, "label": "L1_MISS" },
    { "type": "OUTPUT", "id": "out_l2_h", "x":  400, "y":   20, "label": "L2_HIT" },
    { "type": "OUTPUT", "id": "out_l2_m", "x":  400, "y":   80, "label": "L2_MISS" }
  ],
