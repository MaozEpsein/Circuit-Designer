    { "type": "BUS_MUX", "x":  -80,  "y": -30, "inputCount": 2, "bitWidth": 8, "label": "BMUX 2:1", "id": "bmx" },
    { "type": "OUTPUT",  "x":  220,  "y": -30, "targetValue": 0, "sandbox": true, "bitWidth": 8, "label": "bm_y", "id": "bm_y" },

