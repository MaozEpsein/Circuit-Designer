# Normalize line endings to LF for all detected text files.
# Windows checkouts still see CRLF locally if `core.autocrlf=true`,
# but the repository copy is always LF — so byte-identical tests
# (HDL round-trip, fixture diffs) stay stable across OSes.
* text=auto eol=lf

# Source code — explicit LF (defensive; covered by text=auto above).
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.svg  text eol=lf
*.md   text eol=lf

# CPU programs.
*.asm text eol=lf
*.c   text eol=lf
*.hex text eol=lf

# HDL fixtures — pinned to LF per docs/hdl-plan.md (Phase 3 setup).
*.v   text eol=lf
*.vh  text eol=lf
*.vcd text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
